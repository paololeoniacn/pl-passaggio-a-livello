# Local development secrets — copy this file to .dev.vars and fill in real values.
# .dev.vars is gitignored and never committed.
# In production, set these via: wrangler secret put <KEY>

# Telegram Bot token — get from @BotFather on Telegram:
#   1. Start a chat with @BotFather
#   2. Send /newbot and follow instructions
#   3. Copy the token (format: 123456789:ABCDef...)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Admin chat ID — receives error alerts when the worker has 3+ consecutive failures.
# Get your chat ID by messaging @userinfobot on Telegram.
# Can be your personal chat ID or a private group ID.
ADMIN_CHAT_ID=your_personal_telegram_chat_id_here

# Proxy config — only needed if PROXY_URL is set in wrangler.toml.
# In production, set via: wrangler secret put PROXY_SECRET
# Must match the PROXY_SECRET env var on your Fly.io proxy.
PROXY_SECRET=changeme_generate_a_random_secret
